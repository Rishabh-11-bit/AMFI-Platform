# ─────────────────────────────────────────────────────────────────────────────
# AMFI Platform — Environment Variables
# Copy to .env and fill in your values before running
# ─────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — fine for up to ~100k events)
DATABASE_URL=sqlite+aiosqlite:///./amfi.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://amfi:password@localhost:5432/amfi

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── SNMP Listener ─────────────────────────────────────────────────────────────
# Real devices send SNMP traps to UDP 162.
# Use 1162 here + iptables NAT on the host:
#   sudo iptables -t nat -A PREROUTING -p udp --dport 162 -j REDIRECT --to-port 1162
SNMP_HOST=0.0.0.0
SNMP_PORT=1162
SNMP_COMMUNITY=public

# ── Syslog Listener ───────────────────────────────────────────────────────────
# Devices send syslog to UDP/TCP 514.
# Use 5514 here + iptables NAT:
#   sudo iptables -t nat -A PREROUTING -p udp --dport 514 -j REDIRECT --to-port 5514
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=5514
SYSLOG_PROTOCOL=udp

# ── MQTT (optional) ───────────────────────────────────────────────────────────
MQTT_ENABLED=false
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=amfi/events/#

# ── SLA Thresholds (minutes) ──────────────────────────────────────────────────
SLA_CRITICAL_MINUTES=15
SLA_HIGH_MINUTES=60
SLA_MEDIUM_MINUTES=240
SLA_LOW_MINUTES=1440

# ── Remediation ───────────────────────────────────────────────────────────────
REMEDIATION_POLL_INTERVAL_SECONDS=30
REMEDIATION_MAX_RETRIES=5
SSH_TIMEOUT_SECONDS=30
ANSIBLE_PLAYBOOKS_DIR=./playbooks
TERRAFORM_DIR=./terraform

# ── Notifications (leave blank to disable) ────────────────────────────────────
# Slack: Settings > Apps > Incoming Webhooks
SLACK_WEBHOOK_URL=

# MS Teams: Channel > Connectors > Incoming Webhook
TEAMS_WEBHOOK_URL=

# PagerDuty: Service > Integrations > Events API v2
PAGERDUTY_ROUTING_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
