# ================================================================
# AMFI Agent v4 - Complete Environment Configuration
# Copy this file to .env and fill in your values
# ================================================================

# ── App ──────────────────────────────────────────────────────────
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# Change this before production deployment
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://amfi:amfi_password@localhost:5432/amfi_v4

# ── AI Engine - Ollama (PRIMARY - runs locally, fully offline) ────
# Install: https://ollama.ai
# Pull model: ollama pull llama3.1
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120

# ── AI Engine - Claude API (OPTIONAL upgrade) ─────────────────────
# Leave blank to use Ollama only (recommended for data privacy)
# Add key to use Claude instead of Ollama (better reasoning quality)
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Agent Behaviour ───────────────────────────────────────────────
# Maximum remediation attempts before escalating to L3
AGENT_MAX_ATTEMPTS=3

# Auto-execute low-risk actions (restart_service, clear_disk)
# Set false to require approval for everything
AUTO_EXECUTE_LOW_RISK=true

# Confidence threshold - below this, agent requests human approval
AGENT_CONFIDENCE_THRESHOLD=0.75

# ── SSH ───────────────────────────────────────────────────────────
SSH_TIMEOUT=30
SSH_CONNECT_TIMEOUT=10

# ── Ansible ───────────────────────────────────────────────────────
PLAYBOOKS_DIR=./playbooks

# ── SLA Policies (minutes) ────────────────────────────────────────
# P1 = Critical (service outage, production down)
SLA_P1_RESPONSE=15
SLA_P1_RESOLVE=60

# P2 = High (significant degradation)
SLA_P2_RESPONSE=60
SLA_P2_RESOLVE=240

# P3 = Medium (partial degradation, workaround exists)
SLA_P3_RESPONSE=240
SLA_P3_RESOLVE=1440

# P4 = Low (minor issue, no user impact)
SLA_P4_RESPONSE=1440
SLA_P4_RESOLVE=4320

# ── Email Notifications (SMTP) ────────────────────────────────────
# Leave blank to disable email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=amfi-agent@yourcompany.com

# ── Slack Notifications ───────────────────────────────────────────
# Get webhook URL from: https://api.slack.com/apps
# Leave blank to disable Slack
SLACK_WEBHOOK=

# ── Team Email Addresses ──────────────────────────────────────────
L1_EMAIL=l1-noc@yourcompany.com
L2_EMAIL=l2-noc@yourcompany.com
L3_EMAIL=l3-engineers@yourcompany.com

# ── High Risk Actions (always require human approval) ─────────────
HIGH_RISK_ACTIONS=rollback_config,failover_standby,bounce_interface,scale_resources

# ── NMS Polling ───────────────────────────────────────────────────
# How often to poll NMS tools for new alerts (seconds)
NMS_POLL_SECONDS=300
